{
  "name": "@banyudu/bash-parser",
  "version": "0.5.1",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "src/index.js",
  "description": "Standard-compliant bash parser",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/banyudu/bash-parser.git"
  },
  "bugs": {
    "url": "https://github.com/banyudu/bash-parser/issues"
  },
  "homepage": "https://github.com/banyudu/bash-parser#readme",
  "license": "MIT",
  "author": "banyudu",
  "contributors": [
    "vorpal-js"
  ],
  "scripts": {
    "doc": "doctoc",
    "test": "ava && xo",
    "build": "mgb ./src/modes posix && mgb ./src/modes bash && mgb ./src/modes word-expansion",
    "prepublishOnly": "npm run build",
    "postversion": "npm run build && git push --follow-tags && npm publish",
    "cover-test": "nyc ava && xo",
    "cover-publish": "nyc report --reporter=text-lcov | coveralls"
  },
  "keywords": [],
  "engines": {
    "node": ">=10"
  },
  "devDependencies": {
    "ava": "^0.15.2",
    "coveralls": "^2.11.11",
    "doctoc": "^1.2.0",
    "json5": "^0.5.0",
    "mode-grammar-builder": "^0.6.0",
    "nyc": "^7.0.0",
    "xo": "^0.56.0"
  },
  "files": [
    "src"
  ],
  "nyc": {
    "exclude": [
      "src/modes/posix/built-grammar.js",
      "test/_utils.js"
    ]
  },
  "xo": {
    "ignores": [
      "**/built-grammar.js"
    ],
    "rules": {
      "unicorn/prefer-module": "off",
      "import/extensions": "off",
      "comma-dangle": "off",
      "capitalized-comments": "off",
      "no-template-curly-in-string": "off",
      "padding-line-between-statements": "off",
      "func-names": "off",
      "operator-linebreak": "off",
      "array-element-newline": "off",
      "object-curly-spacing": "off",
      "quote-props": "off",
      "object-shorthand": "off",
      "unicorn/prevent-abbreviations": "off",
      "unicorn/no-thenable": "off",
      "unicorn/filename-case": "off",
      "func-name-matching": "off",
      "prefer-spread": "off",
      "no-multi-assign": "off",
      "n/prefer-global/process": "off",
      "prefer-object-spread": "off",
      "prefer-destructuring": "off",
      "unicorn/prefer-spread": "off",
      "no-mixed-spaces-and-tabs": "off",
      "ava/no-async-fn-without-await": "off"
    },
    "overrides": [
      {
        "files": "test/_benchmark.js",
        "rules": {
          "n/no-unsupported-features/node-builtins": "off"
        }
      }
    ]
  },
  "dependencies": {
    "array-last": "^1.1.1",
    "babylon": "^6.9.1",
    "compose-function": "^3.0.3",
    "curry": "^1.2.0",
    "deep-freeze": "0.0.1",
    "filter-iterator": "0.0.1",
    "filter-obj": "^1.1.0",
    "has-own-property": "^0.1.0",
    "identity-function": "^1.0.0",
    "iterable-lookahead": "^1.0.0",
    "iterable-transform-replace": "^1.1.1",
    "magic-string": "^0.16.0",
    "map-iterable": "^1.0.1",
    "map-obj": "^2.0.0",
    "object-pairs": "^0.1.0",
    "object-values": "^1.0.0",
    "reverse-arguments": "^1.0.0",
    "shell-quote-word": "^1.0.1",
    "to-pascal-case": "^1.0.0",
    "transform-spread-iterable": "^1.1.0",
    "unescape-js": "^1.0.5"
  }
}
